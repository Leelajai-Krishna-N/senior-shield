      "parameters": {
        "jsCode": "// Get the original email body from Gmail Trigger\nconst emailBody = $(\"Gmail Trigger\").item.json.text || \"\";\n\n// Extract URLs (handles normal + <...>)\nconst regex = /(https?:\\/\\/[^\\s<>\"]+|www\\.[^\\s<>\"]+)/gi;\nconst matches = emailBody.match(regex) || [];\n\n// Clean URLs\nconst urls = matches.map(url =>\n  url\n    .replace(/^<|>$/g, \"\")        // remove < >\n    .replace(/[.,)\\]]+$/, \"\")     // remove trailing punctuation\n);\n\n// Deduplicate\nconst uniqueUrls = [...new Set(urls)];\n\n// Return proper n8n format (Code node style)\nreturn [{\n  ...$json,\n  urls: uniqueUrls\n}];"
      },
