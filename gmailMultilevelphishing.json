    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const url = $input.item.json.final_url || \"\";\nlet score = 0;\n\nif (url.match(/\\.(xyz|top|click|loan)/)) score += 0.4;\nif (url.match(/\\d+\\.\\d+\\.\\d+\\.\\d+/)) score += 0.4;\nif (url.includes(\"login\") || url.includes(\"verify\")) score += 0.2;\n\nreturn { ...($input.item.json), link_score: score };"
      },
      "id": "22cbec1a-4e51-4da6-b036-75969e685c42",
      "name": "Link Risk Analysis",
      "type": "n8n-nodes-base.code",
