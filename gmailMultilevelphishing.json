    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const subject = $(\"Gmail Trigger\").item.json.headers.subject || \"\";\nconst body = $(\"Gmail Trigger\").item.json.text || \"\";\nconst text = (subject + \" \" + body).toLowerCase();\n\nlet score = 0;\n\nif (text.includes(\"urgent\") || text.includes(\"immediately\")) score += 0.3;\nif (text.includes(\"otp\") || text.includes(\"password\")) score += 0.3;\nif (text.includes(\"bank\") || text.includes(\"account\")) score += 0.2;\n\nreturn { ...($input.item.json), behavior_score: score };"
      },
      "id": "0f1d21c8-9711-46c1-8ddb-3f327b5d6691",
      "name": "Behavior Analysis",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2704,
        376
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const mlConfidence = $input.item.json.result?.confidence || 0;\nconst mlLabel = $input.item.json.result?.label || \"\";\n\nconst final_score =\n  0.4 * (mlLabel === \"phishing\" ? mlConfidence : 0) +\n  0.2 * ($input.item.json.link_score || 0) +\n  0.2 * ($input.item.json.sender_score || 0) +\n  0.2 * ($input.item.json.behavior_score || 0);\n\nreturn {\n  ...($input.item.json),\n  final_score,\n  is_scam: final_score > 0.5 || (mlLabel === \"phishing\" && mlConfidence > 0.7)\n};"
      },
