        "functionCode": "const explanation = $json.output || $json.text || \"No explanation available.\";\n\nconst html = `\n<h2>⚠️ Scam Detection Alert</h2>\n\n<p><b>Risk Score:</b> ${$json.final_score}</p>\n\n<h3>📧 Email Details</h3>\n<p><b>Subject:</b> ${$('Gmail Trigger').item.json.headers.subject}</p>\n<p><b>From:</b> ${$('Gmail Trigger').item.json.headers.from}</p>\n\n<h3>📊 Risk Breakdown</h3>\n<ul>\n  <li><b>Sender Risk:</b> ${$json.sender_score}</li>\n  <li><b>Link Risk:</b> ${$json.link_score || 0}</li>\n  <li><b>Behavior Risk:</b> ${$json.behavior_score}</li>\n</ul>\n\n<h3>🧠 Explanation</h3>\n<p>${explanation}</p>\n\n<hr>\n<p style=\"color:gray;font-size:12px;\">Generated by AI Scam Detection System</p>\n`;\n\nreturn [{ ...$json, html }];"
      },
