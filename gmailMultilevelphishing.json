    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const sender = $input.item.json.from || \"\";\nlet score = 0;\n\nif (!sender.includes(\"noreply\")) score += 0.1;\nif (sender.match(/\\.xyz|\\.top|\\.click/)) score += 0.4;\nif (sender.includes(\"secure\") || sender.includes(\"verify\")) score += 0.2;\n\nreturn { ...($input.item.json), sender_score: score };"
      },
